{
  "name": "trendradar",
  "version": "1.0.0",
  "description": "Hot Ukrainian news aggregation and analysis platform",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "trendradar": "dist/index.js"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "start": "bun dist/index.js",
    "bot": "bun src/index.ts",
    "bot:prod": "bun dist/index.js",
    "lint": "biome lint src",
    "lint:fix": "biome lint src --write",
    "format": "biome format src --write",
    "check": "biome check src --write",
    "typecheck": "tsc --noEmit",
    "convex:dev": "bunx convex dev",
    "convex:deploy": "bunx convex deploy"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.28",
    "@ai-sdk/deepseek": "^2.0.12",
    "@ai-sdk/google": "^3.0.15",
    "@ai-sdk/openai": "^3.0.21",
    "@aws-sdk/client-s3": "^3.705.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ai": "^6.0.57",
    "axios": "^1.7.9",
    "better-sqlite3": "^11.6.0",
    "convex": "^1.31.7",
    "drizzle-orm": "^0.38.2",
    "grammy": "^1.32.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "openai": "^4.76.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "rss-parser": "^3.13.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
