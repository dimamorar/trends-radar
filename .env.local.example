# TrendRadar Environment Variables
# Copy this file to .env.local and fill in your values

# Required: Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional: Chat ID for push notifications
TELEGRAM_CHAT_ID=

# Optional: AI API Key (required only if AI pipeline is enabled)
AI_API_KEY=

# Optional: S3-compatible storage
# S3_BUCKET_NAME=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT_URL=
# S3_REGION=auto

# Optional: Convex
# CONVEX_URL=
